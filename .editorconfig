# EditorConfig — https://editorconfig.org/
# Cohérence de formatage entre éditeurs de code

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{html,css,js,json,svg}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab
